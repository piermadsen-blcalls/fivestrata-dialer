# Copy to .env and fill in. Never commit .env.

# Server
PORT=3000
HOST=0.0.0.0

# Supabase (Project Settings -> API)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Telnyx (portal.telnyx.com -> API Keys; public key is for webhook signature verification)
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=

# VICIdial HTTP APIs (no official SDK — we call non_agent_api.php / api.php directly)
VICIDIAL_BASE_URL=http://your-vicidial-server
VICIDIAL_API_USER=
VICIDIAL_API_PASS=
# identifies this app in VICIdial API logs
VICIDIAL_SOURCE=ccai
